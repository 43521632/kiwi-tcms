Второй запрос

Вот ваш файл `docker-compose.yml` с применёнными изменениями и улучшениями. 

### 🟢 Легенда пометок:
| Пометка | Значение |
|---------|----------|
| `# ➕ [ДОБАВЛЕНО]` | Новая строка или блок, которого не было в оригинале |
| `# ✏️ [ИЗМЕНЕНО]` | Значение было изменено (старое значение показано в комментарии) |
| `# ⚠️ [ВНИМАНИЕ]` | Важное пояснение или предупреждение |
| `# ➖ [ОПЦИОНАЛЬНО]` | Блок можно удалить, если не нужен |

---

### 📄 Файл: `docker-compose.yml` (модифицированный)

```yaml
# ✏️ [ИЗМЕНЕНО] Версия схемы (было: '2', стало: '3.8' для поддержки современных функций)
version: '3.8'

services:
    db:
        container_name: kiwi_db
        image: mariadb:10.6  # ➕ [ИЗМЕНЕНО] Зафиксирована версия образа (было: mariadb:latest) для стабильности
        command:
            --character-set-server=utf8mb4 --collation-server=utf8mb4_unicode_ci
        volumes:
            - db_data:/var/lib/mysql
        restart: always
        environment:
            # checkov:skip=CKV_SECRET_6:Base64 High Entropy String
            # ✏️ [ИЗМЕНЕНО] Замените на надёжный пароль! (было: kiwi-1s-aw3s0m3)
            MYSQL_ROOT_PASSWORD: ${KIWI_DB_ROOT_PASSWORD:-ChangeMe_R00tP@ss!}
            MYSQL_DATABASE: kiwi
            MYSQL_USER: kiwi
            # ✏️ [ИЗМЕНЕНО] Замените на надёжный пароль! (было: kiwi)
            MYSQL_PASSWORD: ${KIWI_DB_PASSWORD:-ChangeMe_Us3rP@ss!}
        # ➕ [ДОБАВЛЕНО] Healthcheck для корректного порядка запуска
        healthcheck:
            test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
            start_period: 30s
            interval: 10s
            timeout: 5s
            retries: 5

    web:
        container_name: kiwi_web
        depends_on:
            db:
                condition: service_healthy  # ➕ [ИЗМЕНЕНО] Ждём готовности БД, а не просто старта контейнера
        restart: always
        image: pub.kiwitcms.eu/kiwitcms/kiwi:latest
        ports:
            # ➕ [ИЗМЕНЕНО] Привязка к localhost для локальной разработки (было: 80:8080)
            # Уберите "127.0.0.1:", если нужен доступ с других устройств в сети
            - 127.0.0.1:80:8080
            - 127.0.0.1:443:8443
        volumes:
            - uploads:/Kiwi/uploads:Z
            # ➕ [ДОБАВЛЕНО] Монтирование local_settings.py для кастомизации (раскомментируйте, если файл создан)
            # - ./local_settings.py:/venv/lib64/python3.11/site-packages/tcms/settings/local_settings.py:ro
            # ➕ [ДОБАВЛЕНО] Опционально: монтирование папки с доп. настройками
            # - ./tcms_settings_dir:/venv/lib64/python3.11/site-packages/tcms_settings_dir:ro
        environment:
            KIWI_DB_HOST: db
            KIWI_DB_PORT: 3306
            KIWI_DB_NAME: kiwi
            KIWI_DB_USER: kiwi
            # ✏️ [ИЗМЕНЕНО] Должно совпадать с MYSQL_PASSWORD выше
            KIWI_DB_PASSWORD: ${KIWI_DB_PASSWORD:-ChangeMe_Us3rP@ss!}
            # ➕ [ДОБАВЛЕНО] КРИТИЧЕСКИ ВАЖНО: Секретный ключ для Django (сгенерируйте свой!)
            # Команда для генерации: python3 -c 'import secrets; print(secrets.token_urlsafe(50))'
            KIWI_SECRET_KEY: ${KIWI_SECRET_KEY:-CHANGE_THIS_TO_A_RANDOM_SECURE_STRING_MIN_50_CHARS}
            # ➕ [ДОБАВЛЕНО] Часовой пояс (замените на ваш)
            KIWI_TIME_ZONE: Europe/Moscow
            # ➕ [ДОБАВЛЕНО] Опционально: настройки почты (раскомментируйте и заполните при необходимости)
            # KIWI_EMAIL_HOST: smtp.example.com
            # KIWI_EMAIL_PORT: 587
            # KIWI_EMAIL_USER: noreply@example.com
            # KIWI_EMAIL_PASSWORD: ${EMAIL_PASSWORD:-}
            # KIWI_EMAIL_USE_TLS: "true"
        cap_drop:
          - ALL
        # ➕ [ДОБАВЛЕНО] Минимальные capabilities для работы HTTPS
        cap_add:
          - NET_BIND_SERVICE
        # ➕ [ДОБАВЛЕНО] Healthcheck для веб-контейнера
        healthcheck:
            test: ["CMD", "curl", "-fk", "https://localhost:8443/"]
            start_period: 40s
            interval: 30s
            timeout: 10s
            retries: 3
        # ➕ [ДОБАВЛЕНО] Настройка логирования (опционально, для удобства отладки)
        logging:
            driver: "json-file"
            options:
                max-size: "10m"
                max-file: "3"

    # ➖ [ОПЦИОНАЛЬНО] Этот сервис только для тестов. Для продакшена/локальной работы — закомментируйте или удалите.
    # proxy:
    #     container_name: reverse_proxy
    #     image: nginx
    #     volumes:
    #         - ./tests/nginx-proxy/nginx.conf:/etc/nginx/nginx.conf:Z
    #         - ./tests/nginx-proxy/localhost.key:/etc/nginx/localhost.key:Z
    #         - ./tests/nginx-proxy/localhost.crt:/etc/nginx/localhost.crt:Z
    #     ports:
    #         - 4343:8443
    #     depends_on:
    #         - web

volumes:
    db_data:
    uploads:
```

